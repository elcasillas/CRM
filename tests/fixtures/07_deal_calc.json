{
  "description": "Deal calculation functions: parseAmount, calcACV, calcTCV",
  "parseAmount": [
    { "label": "empty string",           "input": ""           },
    { "label": "dollar + commas",        "input": "$1,234.56"  },
    { "label": "plain number string",    "input": "5000"       },
    { "label": "negative value",         "input": "-100"       },
    { "label": "whitespace + symbol",    "input": "  $ 500 "   },
    { "label": "null",                   "input": null         },
    { "label": "non-numeric string",     "input": "abc"        },
    { "label": "zero string",            "input": "0"          }
  ],
  "calcACV": [
    { "label": "12-month term",          "amount": 1000,    "months": 12   },
    { "label": "1-month term (no mult)", "amount": 1000,    "months": 1    },
    { "label": "null term (default ×12)","amount": 1000,    "months": null },
    { "label": "0-month term (×12)",     "amount": 1000,    "months": 0    },
    { "label": "24-month term",          "amount": 1000,    "months": 24   },
    { "label": "string amount, 1-month", "amount": "$500",  "months": 1    },
    { "label": "string amount, 6-month", "amount": "$500",  "months": 6    },
    { "label": "zero amount",            "amount": 0,       "months": 12   },
    { "label": "invalid amount",         "amount": "invalid","months": 6   }
  ],
  "calcTCV": [
    { "label": "1000 × 12",             "amount": "1000",   "months": "12" },
    { "label": "1000 × 1",             "amount": "1000",   "months": "1"  },
    { "label": "1000 × 0",             "amount": "500",    "months": "0"  },
    { "label": "formatted amount × 24", "amount": "$1,200", "months": "24" },
    { "label": "invalid amount",        "amount": "abc",    "months": "12" },
    { "label": "empty months",          "amount": "1000",   "months": ""   },
    { "label": "1000 × 6",             "amount": "1000",   "months": "6"  }
  ]
}
